---
import InfoText from "../components/InfoText.astro";
import KineticTypography from "../components/KineticTypography.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<style>
  .animation-base {
    animation-name: fadeIn;
    animation-duration: 1s;
    animation-fill-mode: both;
    animation-timing-function: ease-in-out;
    opacity: 0;
  }

  .p2 {
    animation-name: fadeIn;
    animation-delay: 0.2s;
  }

  .p3 {
    animation-name: fadeIn;
    animation-delay: 0.4s;
  }

  .p4 {
    animation-name: fadeIn;
    animation-delay: 0.6s;
  }

  .p5 {
    animation-name: fadeIn;
    animation-delay: 0.8s;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<BaseLayout>
  <div
    class="min-w-full grow gird grid-cols-1 lg:h-[calc(100vh-144px)] bg-white"
  >
  Coming Soon...
  </div>
</BaseLayout>
